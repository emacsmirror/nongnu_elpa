@SET_MAKE@

SHELL = /bin/sh
GIT = git

# the version of this package
PACKAGE_VERSION = @PACKAGE_VERSION@
GIT_DIR = "@top_srcdir@/.git"

##############################################################################
# location of required programms
MKDIR = @MKDIR@
RMDIR = @RMDIR@
RM   = @RM@
LS   = @LS@
XARGS = @XARGS@
INSTALL = @INSTALL@
INSTALL_PROGRAM = @INSTALL_PROGRAM@
INSTALL_SCRIPT = @INSTALL_SCRIPT@
INSTALL_DATA = @INSTALL_DATA@
INSTALL_INFO = @INSTALL_INFO@
MAKEINFO = @MAKEINFO@

prefix = @prefix@
srcdir = @srcdir@
datarootdir = @datarootdir@
infodir = @infodir@
infodestdir = $(DESTDIR)$(infodir)

EMACS_PROG = @EMACS_PROG@
EMACS_FLAVOR = @EMACS_FLAVOR@

FLAGS = @FLAGS@

INFO_FILE = vm.info
INFO_ALL_FILES = vm.info vm.info-1 vm.info-2
INFO_INSTALLED = $(infodestdir)/vm.info
INFO_INSTALLED = $(INFO_FILE:%=$(infodestdir)/%)
INFO_ALL_INSTALLED = $(INFO_ALL_FILES:%=$(infodestdir)/%)

##############################################################################

all: info

version.texinfo:
	echo @set VERSION $(PACKAGE_VERSION) > $@.tmp
	if [ -d "$(GIT_DIR)" ]; then \
		echo @set COMMIT `$(GIT) --git-dir="$(GIT_DIR)" rev-parse HEAD` >> $@.tmp; \
	else \
		echo "@set COMMIT unknown" >> $@.tmp; \
	fi
	mv -f $@.tmp $@

$(INFO_FILE): version.texinfo

.PHONY: info
info: ${INFO_FILE}

# Build info file from texinfo source
%.info: %.texinfo 
	$(MAKEINFO) $(MAKEINFO_FLAGS) -o $@ $<

Makefile: @srcdir@/Makefile.in
	cd @srcdir@/.. && ./config.status

install: install-pkg
uninstall: uninstall-pkg

install-pkg: info
	@$(MKDIR) -p -m 0755 "$(infodestdir)";
	$(INSTALL) ${INFO_ALL_FILES} $(infodestdir)
	$(INSTALL_INFO) --dir-file=$(infodestdir)/dir $(INFO_INSTALLED)
	@echo VM INFO files successfully installed

uninstall-pkg:
	$(INSTALL_INFO) --delete --dir-file=$(infodestdir)/dir $(INFO_INSTALLED)
	$(RM) -f $(INFO_ALL_INSTALLED)
	$(RMDIR) $(infodestdir)/ 2> /dev/null || true

##############################################################################
clean:
	-$(RM) -f version.texinfo *.info *.info-[0-9]

distclean: clean
	-$(RM) -f Makefile
