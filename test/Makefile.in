@SET_MAKE@

##############################################################################
# VM Test Suite Makefile
##############################################################################

SHELL = /bin/sh
EMACS_PROG = @EMACS_PROG@
srcdir = @srcdir@
top_srcdir = @top_srcdir@

# Test files
TEST_INIT = vm-test-init.el
TEST_RUNNER = run-tests.el
COVERAGE_RUNNER = coverage-report.el
TEST_FILES = vm-misc-test.el vm-mime-test.el vm-folder-test.el vm-imap-test.el

# Coverage collection: set COVERAGE=1 to enable (e.g., make test COVERAGE=1)
COVERAGE =

##############################################################################
# Test targets
##############################################################################

.PHONY: test test-verbose test-misc test-mime test-folder test-imap test-interactive coverage clean

# Run all tests in batch mode (with optional coverage)
test:
ifeq ($(COVERAGE),1)
	$(EMACS_PROG) -batch -Q -L $(top_srcdir)/lisp -l $(srcdir)/$(COVERAGE_RUNNER)
else
	$(EMACS_PROG) -batch -Q -L $(top_srcdir)/lisp -l $(srcdir)/$(TEST_RUNNER)
endif

# Run tests with coverage collection
coverage:
	$(EMACS_PROG) -batch -Q -L $(top_srcdir)/lisp -l $(srcdir)/$(COVERAGE_RUNNER)

# Run tests with verbose output
test-verbose:
	$(EMACS_PROG) -batch -Q -L $(top_srcdir)/lisp \
	    --eval '(setq ert-batch-print-level 5)' \
	    --eval '(setq ert-batch-print-length 10)' \
	    -l $(srcdir)/$(TEST_RUNNER)

# Run specific test modules
test-misc:
	$(EMACS_PROG) -batch -Q -L $(top_srcdir)/lisp -l $(srcdir)/$(TEST_INIT) \
	    -l $(srcdir)/vm-misc-test.el -f ert-run-tests-batch-and-exit

test-mime:
	$(EMACS_PROG) -batch -Q -L $(top_srcdir)/lisp -l $(srcdir)/$(TEST_INIT) \
	    -l $(srcdir)/vm-mime-test.el -f ert-run-tests-batch-and-exit

test-folder:
	$(EMACS_PROG) -batch -Q -L $(top_srcdir)/lisp -l $(srcdir)/$(TEST_INIT) \
	    -l $(srcdir)/vm-folder-test.el -f ert-run-tests-batch-and-exit

test-imap:
	$(EMACS_PROG) -batch -Q -L $(top_srcdir)/lisp -l $(srcdir)/$(TEST_INIT) \
	    -l $(srcdir)/vm-imap-test.el -f ert-run-tests-batch-and-exit

# Run tests interactively (opens Emacs with ERT buffer)
test-interactive:
	$(EMACS_PROG) -Q -L $(top_srcdir)/lisp -l $(srcdir)/$(TEST_RUNNER) \
	    --eval '(ert t)'

# Clean test artifacts
clean:
	-rm -f $(srcdir)/coverage-results.txt

distclean: clean
	-rm -f Makefile
